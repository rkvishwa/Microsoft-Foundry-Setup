# *.services.ai.azure.com are normalized to append /openai/v1 automatically.
# AZURE_AI_ENDPOINT=https://knurdzorg-test-resource.services.ai.azure.com/openai/v1
# AZURE_AI_DEPLOYMENT=Kimi-K2.6
